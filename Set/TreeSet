	 t.add("hate");
	 t.add("at");
	 t.add("noooot");
	 t.add("back");
	 t.add("lifeofpie");
	 
	 //sorted based on lexographic order of first latter
	 System.out.println(t);
	 
	 //custom sorting order using comparator based on length of string ascending to descending
